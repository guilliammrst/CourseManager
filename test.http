### Get student
GET http://localhost:8080/api/v1/students/1

### Get student enrollments
GET http://localhost:8080/api/v1/students/1/enrollments

### Get students
GET http://localhost:8080/api/v1/students?size=10&page=0

### Create student
POST http://localhost:8080/api/v1/students
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Doe",
  "email": "john@doe.com"
}

### Update student
PUT http://localhost:8080/api/v1/students/1
Content-Type: application/json

{
"firstName": "Updated",
"lastName": "User",
"email": "updated@mail.com"
}

### Delete student
DELETE http://localhost:8080/api/v1/students/1

### Get teacher by id
GET http://localhost:8080/api/v1/teachers/1

### Get teacher courses
GET http://localhost:8080/api/v1/teachers/1/courses

### Get teachers
GET http://localhost:8080/api/v1/teachers?speciality=Math

### Create teacher
POST http://localhost:8080/api/v1/teachers
Content-Type: application/json

{
  "firstName": "Jacques",
  "lastName": "Appart",
  "courseType": "HISTORY"
}

### Update teacher
PUT http://localhost:8080/api/v1/teachers/1
Content-Type: application/json

{
  "firstName": "AliceUpdated",
  "lastName": "MartinUpdated",
  "courseType": "BIOLOGY"
}

### Delete teacher
DELETE http://localhost:8080/api/v1/teachers/1

### Get courses
GET http://localhost:8080/api/v1/courses

### Get course by id
GET http://localhost:8080/api/v1/courses/1

### Get course students
GET http://localhost:8080/api/v1/courses/1/students

### Create course
POST http://localhost:8080/api/v1/courses
Content-Type: application/json

{
  "title": "Art et dessin",
  "description": "Nous allons beaucoup dessiner",
  "courseType": "ART",
  "teacherId": null
}

### Update course
PUT http://localhost:8080/api/v1/courses/1
Content-Type: application/json

{
  "title": "Advanced Math",
  "description": "Advanced algebra",
  "courseType": "COMPUTER_SCIENCE",
  "teacherId": 0
}

### Delete course
DELETE http://localhost:8080/api/v1/courses/1

### Enroll student
POST http://localhost:8080/api/v1/enrollments
Content-Type: application/json

{
  "studentId": 1,
  "courseId": 1,
  "type": "NORMAL"
}

### Enroll student
PUT http://localhost:8080/api/v1/enrollments/1
Content-Type: application/json

{
  "status": "CANCELLED"
}

### Delete enrollment
DELETE http://localhost:8080/api/v1/enrollments/1